@startuml Use_Case_Diagram

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor white
skinparam roundcorner 10
skinparam shadowing false
skinparam defaultFontSize 11

actor "Administrator" as admin
actor "Teacher" as teacher
actor "Form Master" as formmaster
actor "System" as system

rectangle "School Early Warning Support System" {
  
  package "Authentication" {
    usecase "Login with Email" as UC1
    usecase "Setup 2FA" as UC2
    usecase "Verify 2FA Code" as UC3
    usecase "Logout" as UC4
  }
  
  package "User Management" {
    usecase "Create User Account" as UC5
    usecase "Edit User Account" as UC6
    usecase "Disable User Account" as UC7
    usecase "View All Users" as UC8
  }
  
  package "Student Management" {
    usecase "Create Student Record" as UC9
    usecase "Enroll Student in Classroom" as UC10
    usecase "View Student Information" as UC11
    usecase "Update Student Status" as UC12
  }
  
  package "Classroom Management" {
    usecase "Create Classroom" as UC13
    usecase "Assign Form Master" as UC14
    usecase "View Classroom Details" as UC15
  }
  
  package "Academic Management" {
    usecase "Create Subject" as UC16
    usecase "Assign Teacher to Subject" as UC17
    usecase "View Teaching Assignments" as UC18
  }
  
  package "Attendance Tracking" {
    usecase "Create Attendance Session" as UC19
    usecase "Mark Student Attendance" as UC20
    usecase "View Attendance History" as UC21
    usecase "Generate Attendance Report" as UC22
  }
  
  package "Risk Assessment" {
    usecase "Calculate Risk Score" as UC23
    usecase "View Student Risk Profile" as UC24
    usecase "View Risk Analytics" as UC25
  }
  
  package "Alert Management" {
    usecase "View Alerts" as UC26
    usecase "Update Alert Status" as UC27
    usecase "Escalate Alert to Admin" as UC28
  }
  
  package "Intervention Management" {
    usecase "Create Intervention Case" as UC29
    usecase "Document Meeting" as UC30
    usecase "Add Progress Update" as UC31
    usecase "Close Intervention Case" as UC32
    usecase "View Intervention Reports" as UC33
  }
  
  package "Communication" {
    usecase "Send Message" as UC34
    usecase "Receive Message" as UC35
    usecase "View Message History" as UC36
  }
  
  package "Dashboard & Analytics" {
    usecase "View Admin Dashboard" as UC37
    usecase "View Teacher Dashboard" as UC38
    usecase "View Form Master Dashboard" as UC39
    usecase "View System Analytics" as UC40
  }
}

admin --> UC1
admin --> UC2
admin --> UC3
admin --> UC4
admin --> UC5
admin --> UC6
admin --> UC7
admin --> UC8
admin --> UC9
admin --> UC10
admin --> UC11
admin --> UC12
admin --> UC13
admin --> UC14
admin --> UC15
admin --> UC16
admin --> UC17
admin --> UC18
admin --> UC21
admin --> UC37
admin --> UC40

teacher --> UC1
teacher --> UC3
teacher --> UC4
teacher --> UC11
teacher --> UC19
teacher --> UC20
teacher --> UC21
teacher --> UC26
teacher --> UC34
teacher --> UC35
teacher --> UC36
teacher --> UC38

formmaster --> UC1
formmaster --> UC3
formmaster --> UC4
formmaster --> UC11
formmaster --> UC15
formmaster --> UC21
formmaster --> UC24
formmaster --> UC25
formmaster --> UC26
formmaster --> UC27
formmaster --> UC28
formmaster --> UC29
formmaster --> UC30
formmaster --> UC31
formmaster --> UC32
formmaster --> UC33
formmaster --> UC34
formmaster --> UC35
formmaster --> UC36
formmaster --> UC39

UC20 ..> UC23 : <<triggers>>
UC23 ..> UC26 : <<creates>>
UC26 ..> UC29 : <<triggers>>
UC19 ..> UC22 : <<generates>>

system --> UC23

note right of admin
  Full system access
  Manages users, classrooms,
  students, and assignments
end note

note right of teacher
  Records attendance
  Views alerts
  Communicates with
  Form Masters
end note

note right of formmaster
  Manages interventions
  Monitors classroom risks
  Handles student cases
end note

@enduml
