@startuml Simple_Use_Case_Diagram

skinparam actorStyle awesome
skinparam backgroundColor white
skinparam roundcorner 15
skinparam shadowing false
skinparam defaultFontSize 12
skinparam packageStyle rectangle


actor "Administrator" as admin #lightblue
actor "Teacher" as teacher #lightgreen
actor "Form Master" as formmaster #lightyellow

rectangle "School Early Warning Support System" {
  
 
  package "System Management" #DDDDDD {
    usecase "Manage Users\n(Create/Edit/Disable)" as UC1
    usecase "Manage Classrooms" as UC2
    usecase "Enroll Students" as UC3
    usecase "Assign Teachers\nto Subjects" as UC4
  }
  
  
  package "Attendance Management" #E8F5E9 {
    usecase "Create Attendance\nSession" as UC5
    usecase "Mark Student\nAttendance" as UC6
    usecase "View Attendance\nHistory" as UC7
  }
  
  
  package "Risk & Alert Management" #FFF9C4 {
    usecase "View Student\nRisk Profile" as UC8
    usecase "View Alerts" as UC9
    usecase "Update Alert\nStatus" as UC10
  }
  
  package "Intervention Management" #FFE0B2 {
    usecase "Create Intervention\nCase" as UC11
    usecase "Document\nMeeting" as UC12
    usecase "Add Progress\nUpdate" as UC13
    usecase "Close Case" as UC14
  }
  
  
  package "Communication" #E1F5FE {
    usecase "Send Message" as UC15
    usecase "View Messages" as UC16
  }
  
  package "Dashboard" #F3E5F5 {
    usecase "View Dashboard" as UC17
  }
  
  package "Authentication" #FFEBEE {
    usecase "Login with 2FA" as UC18
  }
}


admin --> UC1
admin --> UC2
admin --> UC3
admin --> UC4
admin --> UC17
admin --> UC18


teacher --> UC5
teacher --> UC6
teacher --> UC7
teacher --> UC9
teacher --> UC15
teacher --> UC16
teacher --> UC17
teacher --> UC18


formmaster --> UC8
formmaster --> UC9
formmaster --> UC10
formmaster --> UC11
formmaster --> UC12
formmaster --> UC13
formmaster --> UC14
formmaster --> UC15
formmaster --> UC16
formmaster --> UC17
formmaster --> UC18


UC6 .> UC8 : <<triggers>>
UC8 .> UC9 : <<creates>>
UC9 .> UC11 : <<triggers>>

note right of UC6
  When teacher marks attendance,
  system automatically calculates
  risk score and creates alerts
  if thresholds are exceeded
end note

note right of formmaster
  Manages at-risk students
  through intervention workflow
end note

@enduml
